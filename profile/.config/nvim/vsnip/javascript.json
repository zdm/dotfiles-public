{
    "shebang": {
        "prefix": [
            "#!",
            "shebang"
        ],
        "body": "#!/usr/bin/env node"
    },
    "process.exit()": {
        "prefix": "process.exit()",
        "body": "process.exit()"
    },
    "console.log( $1 )": {
        "prefix": "console.log( $1 )",
        "body": "console.log( $1 )"
    },
    "JSON.stringify": {
        "prefix": "JSON.stringify( $1 )",
        "body": "JSON.stringify( $1 )"
    },
    "JSON.parse": {
        "prefix": "JSON.parse( $1 )",
        "body": "JSON.parse( $1 )"
    },
    "eslint-disable-next-line": {
        "prefix": "// eslint-disable-next-line",
        "body": "// eslint-disable-next-line $1"
    },
    "eslint-disable-line": {
        "prefix": "// eslint-disable-line ",
        "body": "// eslint-disable-line $1"
    },
    "eslint-disable": {
        "prefix": "/* eslint-disable */",
        "body": "/* eslint-disable $1 */"
    },
    "for": {
        "prefix": "for (",
        "body": "for ( let n = 0; n < 1; n++ ) { $1 }"
    },
    "confirm": {
        "prefix": "confirm",
        "body": "await ( await import( \"@softvisio/core/utils\" ) ).confirm( \"Continue?\", [\"y\"] )"
    }
}
