{
    "note": {
        "prefix": [
            "> note"
        ],
        "body": "> \\[!NOTE]\n> $1"
    },
    "tip": {
        "prefix": [
            "> tip"
        ],
        "body": "> \\[!TIP]\n> $1"
    },
    "important": {
        "prefix": [
            "> important"
        ],
        "body": "> \\[!IMPORTANT]\n> $1"
    },
    "warning": {
        "prefix": [
            "> warning"
        ],
        "body": "> \\[!WARNING]\n> $1"
    },
    "caution": {
        "prefix": [
            "> caution"
        ],
        "body": "> \\[!CAUTION]\n> $1"
    },
    "details": {
        "prefix": [
            "details"
        ],
        "body": "<details>\n    <summary>$1</summary>\n\n$2\n\n</details>\n"
    },
    "tabs": {
        "prefix": [
            "tabs"
        ],
        "body": "<!-- tabs:start -->\n\n#### **$1**\n\n$2\n\n#### **$3**\n\n$4\n\n<!-- tabs:end -->\n"
    }
}
