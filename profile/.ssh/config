# NOTE https://man7.org/linux/man-pages/man5/ssh_config.5.html

Host localhost, *.localhost, local.softvisio.net, *.local.softvisio.net, devel
    Compression             no
    ForwardAgent            yes
    GatewayPorts            yes

Host github.com, bitbucket.com, bitbucket.org, gitlab.com
    Compression             yes
    ForwardAgent            no
    GatewayPorts            no

Host *
    CheckHostIP             yes
    Compression             yes
    ForwardAgent            no
    GatewayPorts            no
    HashKnownHosts          yes
    StrictHostKeyChecking   accept-new
    UpdateHostKeys          yes
    VerifyHostKeyDNS        ask
