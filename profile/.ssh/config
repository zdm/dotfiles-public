# NOTE https://man7.org/linux/man-pages/man5/ssh_config.5.html

Host devel
    Compression             no

Host *
    CheckHostIP             yes
    Compression             yes
    ForwardAgent            yes
    GatewayPorts            yes
    StrictHostKeyChecking   accept-new
    UpdateHostKeys          yes
    VerifyHostKeyDNS        ask
